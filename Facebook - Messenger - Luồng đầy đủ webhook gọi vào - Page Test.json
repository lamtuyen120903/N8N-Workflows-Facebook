    {
      "parameters": {
        "jsCode": "// Lấy tất cả các item từ input\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const data = item.json;\n\n  // Lấy sender và recipient từ chính item hiện tại\n  const senderId = $('When Executed by Another Workflow').first().json.messenger[0].sender.id;\n  const recipientId = $('When Executed by Another Workflow').first().json.messenger[0].recipient.id;\n\n  if (!senderId || !recipientId) {\n    throw new Error(\"Thiếu sender.id hoặc recipient.id trong dữ liệu\");\n  }\n\n  // Hàm kiểm tra ID có phải là Page không (Page ID thường < 16 ký tự)\n  const isPageId = (id) => String(id).length < 16;\n\n  let pageId, userId;\n\n  if (isPageId(senderId)) {\n    // Trang gửi tin → người nhận\n    pageId = senderId;\n    userId = recipientId;\n  } else {\n    // Người gửi tin → trang nhận\n    pageId = recipientId;\n    userId = senderId;\n  }\n\n  // Trả về dữ liệu đã được chuẩn hóa\n  results.push({\n    json: {\n      ...data,\n      normalized: {\n        pageId,\n        userId,\n        format: `${pageId}_${userId}`\n      }\n    }\n  });\n}\n\nreturn results;"
      },
